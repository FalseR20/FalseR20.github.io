{
  "name": "falser-dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.html",
    "start": "bun src/index.html",
    "build": "bun run build.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "bun run lint:eslint && bun run tailwind:lint",
    "lint:fix": "bun run lint:eslint:fix && bun run tailwind:lint:fix",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "tailwind:lint": "tailwind-lint --config ./styles/globals.css \"src/**/*.{ts,tsx,css}\"",
    "tailwind:lint:fix": "tailwind-lint --config ./styles/globals.css \"src/**/*.{ts,tsx,css}\" --fix"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "react": "^19",
    "react-dom": "^19",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "globals": "^17.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwind-lint": "^0.9.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  }
}
